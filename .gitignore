# 1. 의존성 모듈 (절대 올리면 안 됨)
node_modules/

# 2. 환경 변수 및 보안 파일 (해킹 방지)
.env
.env.*

# 3. Prisma 관련
/generated/prisma
# SQLite 사용 시 로컬 DB 파일 업로드 방지 (중요)
*.db
*.db-journal

# 4. 로그 파일 (에러 났을 때 생기는 로그들)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# 5. 운영체제 파일 (맥/윈도우에서 자동으로 생기는 쓰레기 파일)
.DS_Store
Thumbs.db

# 6. 에디터 설정 파일 (개인 설정 공유 방지)
.vscode/
.idea/