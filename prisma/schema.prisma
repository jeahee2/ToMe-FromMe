// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

// 1. 회원 (Member)
model Member {
  id       Int      @id @default(autoincrement())
  userid   String   @unique // 아이디
  password String
  name     String
  email    String?
  
  // 👇 핵심: "나는 여러 개의 편지를 가질 수 있다"
  letters  Letter[] 
}

// 2. 편지 (Letter)
model Letter {
  id        Int      @id @default(autoincrement())
  type      String   @default("text") // "text" | "video"
  content   String?  // 텍스트 편지 내용 (영상 편지면 null)
  videoUrl  String?  // R2 영상 URL (텍스트 편지면 null)
  openDate  DateTime // 📅 개봉 예정일
  createdAt DateTime @default(now())
  sentAt    DateTime? // 이메일 발송 시각 (null = 미발송)

  author    Member   @relation(fields: [authorId], references: [id])
  authorId  Int
}